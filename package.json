{
  "name": "resume-with-openai",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7342",
    "dev:film-bridge": "next dev -p 3007",
    "build": "tsx scripts/generate-image-manifest.ts && tsx scripts/generate-article-manifest.ts && tsx scripts/generate-recommendation-index.ts && pnpm run embeddings && next build",
    "postbuild": "tsx scripts/generate-video-sitemap.ts && next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run type-check",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "embeddings": "tsx lib/generate-embeddings.ts",
    "embeddings:refresh": "tsx lib/generate-embeddings.ts --refresh",
    "generate:multi-art": "tsx scripts/generate-multi-art.ts",
    "generate:multi-art:dry-run": "tsx scripts/generate-multi-art.ts --dry-run",
    "generate:multi-art:fast": "tsx scripts/generate-multi-art.ts --limit 5",
    "generate:article": "tsx scripts/generate-article-ai.ts",
    "generate:knowledge": "tsx scripts/generate-knowledge-base.ts",
    "generate:knowledge:all": "tsx scripts/generate-knowledge-base.ts --all",
    "generate:knowledge:seo": "tsx scripts/generate-knowledge-base.ts --high-seo",
    "generate:fal-assets": "tsx scripts/generate-fal-assets.ts",
    "generate:top-article-images": "tsx scripts/generate-top-article-images.ts",
    "generate:top-article-images:all": "tsx scripts/generate-top-article-images.ts --all",
    "acc:generate": "tsx scripts/acc-batch-generate-and-grade.ts",
    "acc:generate:preview": "tsx scripts/acc-batch-generate-and-grade.ts --preview",
    "acc:generate:force": "tsx scripts/acc-batch-generate-and-grade.ts --force",
    "acc:generate:strict": "tsx scripts/acc-batch-generate-and-grade.ts --min-score 7.0 --auto-retry",
    "genstack:start": "tsx scripts/generation-stack-manager.ts start",
    "genstack:stop": "tsx scripts/generation-stack-manager.ts stop",
    "genstack:status": "tsx scripts/generation-stack-manager.ts status",
    "genstack:restart": "tsx scripts/generation-stack-manager.ts restart",
    "test:grader": "vitest run --config vitest.node.config.ts tests/image-grader.test.ts",
    "test:acc-client": "vitest run --config vitest.node.config.ts tests/acc-client.test.ts",
    "test:node": "vitest run --config vitest.node.config.ts",
    "validate:stack": "tsx scripts/validate-generation-stack.ts",
    "validate:stack:live": "tsx scripts/validate-generation-stack.ts --start-services",
    "test:visual": "node tests/visual-test-runner.js",
    "test:visual:enhanced": "node tests/enhanced-visual-test-runner.js",
    "test:visual:analyze": "node tests/feedback-analyzer.js",
    "test:visual:full": "npm run test:visual:enhanced && npm run test:visual:analyze",
    "test:visual:install": "pnpm add -D playwright && npx playwright install chromium",
    "setup:media-storage": "tsx scripts/setup-media-storage.ts",
    "generate:series-images": "tsx scripts/generate-series-images.ts",
    "generate:series-images:dry-run": "tsx scripts/generate-series-images.ts --all --dry-run",
    "generate:series-images:missing": "tsx scripts/generate-series-images.ts --all --option 2 --only-missing",
    "generate:series-videos": "tsx scripts/generate-series-videos.ts",
    "generate:series-videos:dry-run": "tsx scripts/generate-series-videos.ts --all --dry-run",
    "generate:series-videos:t2v": "tsx scripts/generate-series-videos.ts --all --t2v-only",
    "narrative": "tsx scripts/narrative-compose.ts",
    "narrative:graph": "tsx scripts/narrative-compose.ts graph",
    "narrative:arc": "tsx scripts/narrative-compose.ts arc",
    "narrative:bridges": "tsx scripts/narrative-compose.ts bridges",
    "narrative:paths": "tsx scripts/narrative-compose.ts paths",
    "film-bridge:start": "tsx scripts/film-bridge-manager.ts start",
    "film-bridge:stop": "tsx scripts/film-bridge-manager.ts stop",
    "film-bridge:status": "tsx scripts/film-bridge-manager.ts status",
    "film-bridge:restart": "tsx scripts/film-bridge-manager.ts restart",
    "bun:install": "bun install",
    "bun:dev": "bun run next dev",
    "bun:dev:film-bridge": "bun run next dev -p 3007",
    "bun:build": "bun run scripts/generate-image-manifest.ts && bun run scripts/generate-article-manifest.ts && bun run scripts/generate-recommendation-index.ts && bun run lib/generate-embeddings.ts && bun run next build",
    "bun:start": "bun run next start",
    "bun:film-bridge:start": "bun run scripts/film-bridge-bun.ts start",
    "bun:film-bridge:stop": "bun run scripts/film-bridge-bun.ts stop",
    "bun:film-bridge:status": "bun run scripts/film-bridge-bun.ts status",
    "bun:e2e": "bun run scripts/e2e-test.ts"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "endOfLine": "lf",
    "sqlKeywordCase": "lower"
  },
  "dependencies": {
    "@gradio/client": "^2.1.0",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/xr": "^6.6.28",
    "@supabase/supabase-js": "^2.45.1",
    "ai": "^2.2.37",
    "class-variance-authority": "^0.4.0",
    "clsx": "^1.2.1",
    "cmdk": "^0.2.1",
    "common-tags": "^1.8.2",
    "framer-motion": "^12.23.26",
    "github-slugger": "^2.0.0",
    "gpt3-tokenizer": "^1.1.5",
    "gray-matter": "^4.0.3",
    "hover.css": "^2.3.2",
    "lucide-react": "^0.128.0",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^1.3.1",
    "mdast-util-mdx": "^2.0.1",
    "mdast-util-to-markdown": "^1.5.0",
    "mdast-util-to-string": "^3.2.0",
    "micromark-extension-mdxjs": "^1.0.1",
    "next": "15.5.10",
    "next-sitemap": "^4.2.3",
    "openai": "^3.3.0",
    "openai-edge": "^1.2.2",
    "postprocessing": "^6.38.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.4",
    "styled-components": "^6.1.12",
    "tailwind-merge": "^1.14.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0",
    "undici": "^7.22.0",
    "unist-builder": "^3.0.1",
    "unist-util-filter": "^4.0.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react-dom": "^19.0.2",
    "@types/common-tags": "^1.8.4",
    "@types/estree": "^1.0.5",
    "@types/mdast": "^3.0.15",
    "@types/node": "^22.18.12",
    "@types/react": "^19.2.2",
    "@types/three": "^0.182.0",
    "@types/yargs": "^17.0.33",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.10",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.41",
    "postcss-nesting": "^12.1.5",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@9.7.1+sha512.faf344af2d6ca65c4c5c8c2224ea77a81a5e8859cbc4e06b1511ddce2f0151512431dd19e6aff31f2c6a8f5f2aced9bd2273e1fed7dd4de1868984059d2c4247"
}
