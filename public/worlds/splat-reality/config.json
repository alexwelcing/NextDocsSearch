{
  "id": "splat-reality",
  "name": "Organic Garden",
  "description": "An immersive organic environment with floating particles and natural elements",
  "version": "2.0.0",
  "assets": {
    "environment": "/splats/splat4s.spz",
    "fallbackPanorama": "/backgrounds/default.jpg"
  },
  "camera": {
    "initial": [0, 1.5, 8],
    "target": [0, 0, 0],
    "fov": 50,
    "constraints": {
      "minDistance": 3,
      "maxDistance": 20,
      "minPolarAngle": 0.4,
      "maxPolarAngle": 1.3,
      "enablePan": true
    }
  },
  "lighting": {
    "preset": "natural",
    "ambient": 0.4,
    "directionalIntensity": 0.8,
    "accentColor": "#F5D547",
    "secondaryColor": "#4A7C59",
    "shadowsEnabled": false,
    "envMapIntensity": 0.6
  },
  "atmosphere": {
    "fog": {
      "enabled": true,
      "color": "#FFFEFB",
      "near": 10,
      "far": 40
    },
    "particles": {
      "type": "pollen",
      "intensity": 0.4,
      "color": "#F5D547"
    }
  },
  "postProcessing": {
    "bloom": {
      "enabled": true,
      "intensity": 0.3,
      "threshold": 0.7,
      "radius": 0.4
    },
    "colorGrading": {
      "enabled": true,
      "saturation": 1.05,
      "contrast": 1.02,
      "brightness": 1.05,
      "warmth": 1.1
    },
    "vignette": {
      "enabled": true,
      "intensity": 0.2
    }
  },
  "theme": {
    "colors": {
      "sun": "#F5D547",
      "flora": "#4A7C59",
      "earth": "#5D4037",
      "parchment": "#FFFEFB"
    }
  },
  "meta": {
    "tags": ["organic", "3d", "garden", "natural", "flora"],
    "author": "System",
    "thumbnail": "/thumbnails/organic-garden.jpg"
  }
}
